# ============================================================
# COMPLETE CODE - Run all cells top to bottom
# This will train the model and save a fresh model.pkl
# ============================================================

# Cell 1 - Import libraries
import numpy as np
import pandas as pd
import pickle
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import accuracy_score

# Cell 2 - Load dataset
df = pd.read_csv("Sonar.csv", header=None)
print("Shape:", df.shape)
print(df.head())

# Cell 3 - Separate features and labels
X = df.drop(columns=60, axis=1)
Y = df[60]
print("X shape:", X.shape)
print("Y values:", Y.value_counts())

# Cell 4 - Train test split
X_train, X_test, Y_train, Y_test = train_test_split(
    X, Y, test_size=0.1, stratify=Y, random_state=1
)
print("Train size:", X_train.shape)
print("Test size:", X_test.shape)

# Cell 5 - Train model
model = LogisticRegression(max_iter=1000)
model.fit(X_train, Y_train)

# Cell 6 - Check accuracy
train_acc = accuracy_score(model.predict(X_train), Y_train)
test_acc  = accuracy_score(model.predict(X_test),  Y_test)
print(f"Training Accuracy : {train_acc:.4f}")
print(f"Testing  Accuracy : {test_acc:.4f}")

# Cell 7 - Save model.pkl
with open("model.pkl", "wb") as f:
    pickle.dump(model, f)
print("model.pkl saved!")

# Cell 8 - Verify it loads correctly
with open("model.pkl", "rb") as f:
    test_load = pickle.load(f)

sample = np.random.rand(1, 60)
pred = test_load.predict(sample)
print("Test prediction:", pred)
print("model.pkl is working correctly!")

# Cell 9 - Print your exact scikit-learn version (IMPORTANT)
